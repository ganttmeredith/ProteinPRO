# ProteinPRO API Keys - Hack Duke 2026
# Copy to .env and fill in for full functionality
# All keys are optional; the app works without them

# Gemini API (Best Use of Generative AI)
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ElevenLabs (Best Accessibility Hack)
# Get key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Solana (optional - for formulation verification)
# SOLANA_PRIVATE_KEY=
# SOLANA_WALLET=

# Auth0 (optional - for user sessions and PDB caching)
# Get: https://auth0.com/dashboard
# Create a "Regular Web Application" and add http://localhost:8501/oauth2callback to Allowed Callback URLs
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Optional: for production deploy
# AUTH0_REDIRECT_URI=https://your-app.com/oauth2callback
# AUTH0_COOKIE_SECRET=use-a-random-32-char-string
